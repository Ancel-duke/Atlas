NODE_ENV=development
ATLAS_ENVIRONMENT=local
ATLAS_LOG_LEVEL=info
ATLAS_API_PORT=4000
ATLAS_WEB_PORT=3000
ATLAS_WORKER_CONCURRENCY=4
ATLAS_JWT_ISSUER=atlas-local
ATLAS_JWT_AUDIENCE=atlas-api
ATLAS_JWT_SECRET=replace-with-a-32-character-development-secret
ATLAS_INTERNAL_API_SECRET=replace-with-a-32-character-internal-api-secret
AUTH_SECRET=replace-with-a-32-character-development-secret
AUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=replace-with-github-oauth-client-id
AUTH_GITHUB_SECRET=replace-with-github-oauth-client-secret
ATLAS_API_INTERNAL_URL=http://localhost:4000
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas?schema=public
REDIS_URL=redis://localhost:6380
OTEL_SERVICE_NAME=atlas
