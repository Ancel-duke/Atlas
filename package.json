{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "node scripts/run-workspace-task.mjs build",
    "clean": "node scripts/run-workspace-task.mjs clean",
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @atlas/api dev",
    "dev:web": "pnpm --filter @atlas/web dev",
    "dev:worker": "pnpm --filter @atlas/worker dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "node scripts/run-workspace-task.mjs lint",
    "test": "node scripts/run-workspace-task.mjs test",
    "typecheck": "node scripts/run-workspace-task.mjs typecheck",
    "turbo:build": "turbo run build",
    "turbo:lint": "turbo run lint",
    "turbo:test": "turbo run test",
    "turbo:typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @atlas/database prisma:generate",
    "db:deploy": "pnpm --filter @atlas/database prisma:deploy",
    "db:migrate": "pnpm --filter @atlas/database prisma:migrate",
    "openapi:generate": "pnpm --filter @atlas/api openapi:generate",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.3.5",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}": [
      "prettier --check"
    ],
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint"
    ]
  }
}
